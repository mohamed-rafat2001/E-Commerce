{
	"name": "e-commerce",
	"version": "1.0.0",
	"description": "e-commerce project",
	"license": "ISC",
	"author": "RAFAT",
	"type": "module",
	"main": "server.js",
	"scripts": {
		"start": "node server.js",
		"build": "echo 'Building serverless functions'",
		"server": "cross-env NODE_MODE=DEV nodemon server.js",
		"client": "npm run dev --prefix ../client",
		"dev": "concurrently \"npm run server\" \"npm run client\"",
		"test": "cross-env NODE_OPTIONS=--experimental-vm-modules NODE_MODE=DEV jest --runInBand"
	},
	"dependencies": {
		"bcryptjs": "^3.0.3",
		"cloudinary": "^2.10.0",
		"compression": "^1.8.1",
		"concurrently": "^9.2.1",
		"cookie-parser": "^1.4.7",
		"cors": "^2.8.6",
		"crypto": "^1.0.1",
		"express": "^5.2.1",
		"express-mongo-sanitize": "^2.2.0",
		"express-rate-limit": "^8.5.2",
		"express-validator": "^7.3.2",
		"helmet": "^8.2.0",
		"hpp": "^0.2.3",
		"ioredis": "^5.11.0",
		"jsonwebtoken": "^9.0.3",
		"mongoose": "^9.6.3",
		"multer": "^2.1.1",
		"nodemailer": "^7.0.13",
		"serverless-http": "^4.0.0",
		"slugify": "^1.6.9",
		"swagger-jsdoc": "^6.3.0",
		"swagger-ui-express": "^5.0.1",
		"validator": "^13.15.35"
	},
	"devDependencies": {
		"@eslint/js": "^9.25.0",
		"cross-env": "^10.1.0",
		"dotenv": "^17.4.2",
		"eslint": "^9.25.0",
		"eslint-plugin-import": "^2.32.0",
		"globals": "^17.6.0",
		"jest": "^30.4.2",
		"mongodb-memory-server": "^11.2.0",
		"nodemon": "^3.1.14",
		"supertest": "^7.2.2"
	},
	"overrides": {
		"path-to-regexp": "^8.4.0",
		"qs": "^6.15.2",
		"picomatch@^2.0.4": "^2.3.2",
		"brace-expansion@^5.0.0": "^5.0.6"
	}
}
